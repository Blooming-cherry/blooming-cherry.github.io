<% const accent = theme.main_accent || "#f0a030"; %>

<article class="post-page" style="--accent: <%- accent %>;">
  <div class="container">
    <header class="post-header">
      <div class="post-badge"><%= theme.main_badge || "罗德岛 · PRTS" %></div>
      <h1><%= page.title %></h1>
    </header>

    <div class="post-body">
      <%- page.content %>
    </div>
  </div>
</article>